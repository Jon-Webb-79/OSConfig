#!/usr/bin/env bash
# ==============================================================================
# backup_drive.sh
# ------------------------------------------------------------------------------
# Purpose:
#   Create timestamped full-system rsync snapshots on a dedicated backup drive,
#   while retaining only the newest N snapshots.
#
# Key safety improvements over the earlier version:
#   - No interactive drive selection
#   - Uses one fixed backup root
#   - Refuses to run if the backup root is empty or unsafe
#   - Refuses to prune outside the intended snapshot directory
#   - Quotes variables consistently
#   - Uses strict shell settings
#
# Exit Codes
#   0  Success
#   1  Unsupported Linux distribution
#   2  rsync not installed
#   3  Backup mount point not found
#   4  Backup root could not be created
#   5  Unsafe backup root / prune path
#   6  rsync backup failed
#   7  Snapshot creation failed
# ==============================================================================

set -euo pipefail
IFS=$'\n\t'

# ------------------------------------------------------------------------------
# Configuration
# ------------------------------------------------------------------------------

NUM_DIRS=4

# Change this to match the mounted name of your backup drive.
# Example:
#   BACKUP_DRIVE_NAME="MyPassport"
BACKUP_DRIVE_NAME="LinuxPopBack"

# Optional subdirectory on the backup drive to hold all snapshots
SNAPSHOT_PARENT="system_snapshots"

LOG_DIR_NAME="logfiles"
LOG_FILE_NAME="backup_log.log"

RSYNC_BIN="/usr/bin/rsync"
MKDIR_BIN="/usr/bin/mkdir"
RM_BIN="/usr/bin/rm"
FIND_BIN="/usr/bin/find"
DATE_BIN="/usr/bin/date"
HOSTNAME_BIN="/usr/bin/hostname"

# ------------------------------------------------------------------------------
# Helper functions
# ------------------------------------------------------------------------------

log_msg() {
    local msg="$1"
    local log_file="$2"
    printf '%s\n' "$msg" >> "$log_file"
}

fail() {
    local code="$1"
    local msg="$2"
    local log_file="$3"

    printf 'ERROR: %s\n' "$msg" >&2
    log_msg "$msg" "$log_file"
    exit "$code"
}

require_command() {
    local cmd="$1"
    local exit_code="$2"
    local err_msg="$3"
    local log_file="$4"

    if ! command -v "$cmd" >/dev/null 2>&1; then
        fail "$exit_code" "$err_msg" "$log_file"
    fi
}

# Ensure a path is non-empty and not something dangerous.
assert_safe_snapshot_root() {
    local path="$1"

    if [[ -z "$path" ]]; then
        return 1
    fi

    case "$path" in
        "/"|"/home"|"/media"|"/run"|"/mnt"|"/media/"*"/"|"/run/media/"*"/")
            return 1
            ;;
    esac

    # Require the path to include the snapshot parent directory name.
    [[ "$path" == *"/${SNAPSHOT_PARENT}" ]]
}

# ------------------------------------------------------------------------------
# Determine username
# ------------------------------------------------------------------------------

if [[ -n "${SUDO_USER:-}" ]]; then
    username="$SUDO_USER"
else
    username="${USER:-$(id -un)}"
fi

# ------------------------------------------------------------------------------
# Setup timestamps and log path
# ------------------------------------------------------------------------------

DATE_STR="$("$DATE_BIN" +%F_%H-%M-%S)"
HOST_STR="$("$HOSTNAME_BIN" 2>/dev/null || echo "unknown-host")"

LOG_DIR="/home/$username/$LOG_DIR_NAME"
LOG_FILE="$LOG_DIR/$LOG_FILE_NAME"

"$MKDIR_BIN" -p "$LOG_DIR"

# ------------------------------------------------------------------------------
# Determine mount base by distribution
# ------------------------------------------------------------------------------

linux_file="/etc/os-release"
media_base=""

if grep -qi "Arch" "$linux_file"; then
    media_base="/run/media/$username"
elif grep -qiE "Ubuntu|Pop" "$linux_file"; then
    media_base="/media/$username"
else
    fail 1 \
        "$username backup failed on $DATE_STR: Linux distribution not supported" \
        "$LOG_FILE"
fi

# ------------------------------------------------------------------------------
# Check required commands
# ------------------------------------------------------------------------------

require_command rsync 2 \
    "$username backup failed on $DATE_STR: rsync not installed" \
    "$LOG_FILE"

require_command find 2 \
    "$username backup failed on $DATE_STR: find not installed" \
    "$LOG_FILE"

require_command stat 2 \
    "$username backup failed on $DATE_STR: stat not installed" \
    "$LOG_FILE"

require_command sort 2 \
    "$username backup failed on $DATE_STR: sort not installed" \
    "$LOG_FILE"

require_command head 2 \
    "$username backup failed on $DATE_STR: head not installed" \
    "$LOG_FILE"

require_command cut 2 \
    "$username backup failed on $DATE_STR: cut not installed" \
    "$LOG_FILE"

# ------------------------------------------------------------------------------
# Build fixed backup paths
# ------------------------------------------------------------------------------

BACKUP_MOUNT="$media_base/$BACKUP_DRIVE_NAME"
BACKUP_ROOT="$BACKUP_MOUNT/$SNAPSHOT_PARENT"
SNAPSHOT_DIR="$BACKUP_ROOT/${HOST_STR}_${DATE_STR}"

if [[ ! -d "$BACKUP_MOUNT" ]]; then
    fail 3 \
        "$username backup failed on $DATE_STR: backup drive not mounted at $BACKUP_MOUNT" \
        "$LOG_FILE"
fi

if ! assert_safe_snapshot_root "$BACKUP_ROOT"; then
    fail 5 \
        "$username backup failed on $DATE_STR: unsafe backup root '$BACKUP_ROOT'" \
        "$LOG_FILE"
fi

if ! "$MKDIR_BIN" -p "$BACKUP_ROOT"; then
    fail 4 \
        "$username backup failed on $DATE_STR: could not create backup root '$BACKUP_ROOT'" \
        "$LOG_FILE"
fi

if ! "$MKDIR_BIN" -p "$SNAPSHOT_DIR"; then
    fail 7 \
        "$username backup failed on $DATE_STR: could not create snapshot dir '$SNAPSHOT_DIR'" \
        "$LOG_FILE"
fi

# ------------------------------------------------------------------------------
# Run backup
# ------------------------------------------------------------------------------

printf 'Starting backup to: %s\n' "$SNAPSHOT_DIR"

if ! sudo "$RSYNC_BIN" -aAXH --numeric-ids --info=progress2 \
    --delete \
    --exclude="/dev/*" \
    --exclude="/proc/*" \
    --exclude="/sys/*" \
    --exclude="/run/*" \
    --exclude="/tmp/*" \
    --exclude="/mnt/*" \
    --exclude="/media/*" \
    --exclude="/lost+found" \
    --exclude="/swapfile" \
    --exclude="/var/tmp/*" \
    / "$SNAPSHOT_DIR/"; then
    fail 6 \
        "$username backup failed on $DATE_STR: rsync returned non-zero status" \
        "$LOG_FILE"
fi

# ------------------------------------------------------------------------------
# Retention: keep only newest NUM_DIRS snapshots
# ------------------------------------------------------------------------------

if ! assert_safe_snapshot_root "$BACKUP_ROOT"; then
    fail 5 \
        "$username backup failed on $DATE_STR: prune refused for unsafe path '$BACKUP_ROOT'" \
        "$LOG_FILE"
fi

mapfile -d '' snapshot_dirs < <(
    find "$BACKUP_ROOT" -mindepth 1 -maxdepth 1 -type d -print0
)

dir_count="${#snapshot_dirs[@]}"

if (( dir_count > NUM_DIRS )); then
    num_delete=$(( dir_count - NUM_DIRS ))

    mapfile -d '' dirs_to_delete < <(
        stat --printf='%Y %n\0' "$BACKUP_ROOT"/* \
        | sort -znk1,1 \
        | head -zn "$num_delete" \
        | cut -z -d ' ' -f2-
    )

    for old_dir in "${dirs_to_delete[@]}"; do
        [[ -n "$old_dir" ]] || continue

        # Double safety check: only delete directories directly under BACKUP_ROOT
        if [[ "$old_dir" == "$BACKUP_ROOT"/* ]] && [[ -d "$old_dir" ]]; then
            printf 'Removing old snapshot: %s\n' "$old_dir"
            sudo "$RM_BIN" -rf -- "$old_dir"
        fi
    done
fi

# ------------------------------------------------------------------------------
# Success log
# ------------------------------------------------------------------------------

success_msg="$username backup completed successfully on $DATE_STR to $SNAPSHOT_DIR"
log_msg "$success_msg" "$LOG_FILE"
printf '%s\n' "$success_msg"

exit 0
